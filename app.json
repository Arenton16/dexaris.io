{
  "expo": {
    "name": "Dexaris",
    "slug": "Dexaris",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.dexaris.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B14"
      },
      "edgeToEdgeEnabled": true,
      "package": "io.dexaris.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "dexaris"
  }
}
